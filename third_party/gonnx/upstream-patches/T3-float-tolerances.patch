diff --git a/ops/linearregressor/linear_regressor_test.go b/ops/linearregressor/linear_regressor_test.go
index 59c021c..ce85661 100644
--- a/ops/linearregressor/linear_regressor_test.go
+++ b/ops/linearregressor/linear_regressor_test.go
@@ -145,7 +145,11 @@ func TestLinearRegressor(t *testing.T) {
 		res, err := linearRegressor.Apply(inputs)
 		assert.Nil(t, err, test.description)
 		assert.Equal(t, test.expectedShape, res[0].Shape(), test.description)
-		assert.Equal(t, test.expectedBacking, res[0].Data(), test.description)
+		// Tolerance, not exact equality: the expected values were baked on another
+		// platform and differ from arm64 output in the last float32 ULP (e.g.
+		// 0.039368242 vs 0.039368212, ~3e-8). The math is correct. 1e-3 matches
+		// TestOps (SOP-75).
+		assert.InDeltaSlice(t, test.expectedBacking, res[0].Data(), 1e-3, test.description)
 	}
 }
 
