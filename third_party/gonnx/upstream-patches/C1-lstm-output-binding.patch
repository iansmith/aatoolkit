index f7bc057..5c3434d 100644
--- a/ops/lstm/lstm.go
+++ b/ops/lstm/lstm.go
@@ -244,16 +244,14 @@ func (l *LSTM) Apply(inputs []tensor.Tensor) ([]tensor.Tensor, error) {
 		return nil, err
 	}
 
-	outputMap := map[string]tensor.Tensor{
-		"Y": Y, "Y_h": Yh, "Y_c": Yc,
-	}
-
-	result := []tensor.Tensor{}
-	for _, outputName := range l.outputs {
-		result = append(result, outputMap[outputName])
-	}
-
-	return result, nil
+	// ONNX LSTM outputs are positional (Y, Y_h, Y_c) and the executor binds them positionally,
+	// so return them by position, truncated to the number the node declares (LSTM may declare
+	// 0–3). Keying by canonical names would return nil for any node whose output names differ
+	// from "Y"/"Y_h"/"Y_c" (e.g. the Silero decoder LSTM). Cap at 3 so a malformed node that
+	// declares >3 outputs yields a length mismatch error downstream rather than a slice panic.
+	nOutputs := min(len(l.outputs), 3)
+
+	return []tensor.Tensor{Y, Yh, Yc}[:nOutputs], nil
 }
 
