+// reshapeToChannelBlock reshapes a sliced sub-image or sub-kernel in place to its
+// canonical [nChannels, kernelShape...] shape. The convolution loops slice a
+// sub-image and a sub-kernel out of higher-rank tensors and then multiply them;
+// gorgonia's Dense.Slice drops every sliced length-1 axis, and it drops them
+// inconsistently between the two (a 1x1 conv leaves the sub-image as [C] but the
+// sub-kernel as [C,1]), which leaves UnidirectionalBroadcast unable to align them.
+// Restoring both to the same canonical rank keeps the subsequent broadcast valid —
+// including the legitimate case of a single-channel kernel broadcast across a
+// multi-channel image — for every conv shape, unit axes or not.
+func (c *Conv) reshapeToChannelBlock(t tensor.Tensor, nChannels int) error {
+	shape := make([]int, 0, 1+len(c.kernelShape))
+	shape = append(shape, nChannels)
+	shape = append(shape, c.kernelShape...)
+
+	return t.Reshape(shape...)
 }
 
