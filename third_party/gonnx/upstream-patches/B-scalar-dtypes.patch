+// A scalar bool must be wrapped into []bool just like every numeric scalar, otherwise
+// ConvertTensorDtype's backing.([]bool) assertion panics on a rank-0 bool tensor.
+func TestIfScalarToSliceBool(t *testing.T) {
+	assert.Equal(t, []bool{true}, IfScalarToSlice(true))
+	assert.Equal(t, []bool{false}, IfScalarToSlice(false))
